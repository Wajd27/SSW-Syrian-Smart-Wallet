# Copy to .env and fill in values.
# Use the SyrianSmartWallet Firebase project (same as .firebaserc / firebase CLI).

# Optional: extra allowed browser origins (comma-separated). Firebase Hosting is included in code by default.
# CORS_ORIGIN=https://your-preview--syriansmartwallet.web.app

JWT_SECRET=replace-with-a-long-random-string

# Must match the Firebase/GCP project you deploy to (service account key must be from this project).
FIREBASE_PROJECT_ID=syriansmartwallet

# Easiest on Windows: path to the downloaded JSON (avoid pasting JSON into .env).
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\secrets\syriansmartwallet-adminsdk.json
#
# Or one line (no line breaks):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"syriansmartwallet",...}

# Optional override; default is {projectId}.appspot.com
# FIREBASE_STORAGE_BUCKET=syriansmartwallet.appspot.com

# --- Image / file uploads: Vercel Blob (optional), then Firebase Storage ---
# Recommended on Vercel: create a Blob store (Dashboard → Storage → Blob), then add the token to this project.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Verify Firestore (writes system/bootstrap): npm run db:prepare
